<?xml version="1.0" encoding="windows-1252"?>
<!--
  WiX v3 source for roomler-agent MSI.

  Build with `cargo wix -p roomler-agent` which invokes candle + light
  against this file.

  Install scope: per-user (InstallScope="perUser"). No UAC prompt and no
  admin rights required. Files land under
  %LOCALAPPDATA%\Programs\roomler-agent\ and config / state stays under
  %APPDATA%\roomler-agent\ (written by the `directories` crate at runtime).

  Autostart: registered automatically on every install + upgrade via the
  RegisterAutostart custom action below. The action shells out to
  `roomler-agent service install` which writes a Schema 1.2 Task
  Scheduler XML with restart-on-failure + battery-defeat settings (see
  agents/roomler-agent/src/service.rs::render_task_xml). Symmetric
  UnregisterAutostart hook runs `service uninstall` before the EXE is
  removed during uninstall. Both actions Return="ignore" so an
  individual machine where the existing task has a tightened ACL (rare
  Win11 quirk that bit us 2026-04-29) doesn't sink the whole MSI —
  operator can still recover via the manual schtasks delete + service
  install path documented in packaging/windows/README.txt.

  Why this works without UAC: perUser MSIs run in the user's token
  context. Custom actions with Execute="deferred" Impersonate="yes"
  (which is the default in perUser mode) inherit that token. schtasks
  /Create /XML /F against a non-elevated task succeeds for the user
  who owns it.
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
    <Product
        Id='*'
        Name='Roomler Agent'
        UpgradeCode='1F2D7B1C-8B2F-4D2E-B1A3-6B1E2C7E4D91'
        Manufacturer='Goran Jovanov'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package
            Id='*'
            Keywords='Installer'
            Description='Roomler AI remote-control agent'
            Manufacturer='Goran Jovanov'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perUser'
            SummaryCodepage='1252' />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.' />

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' />
        <Property Id='DiskPrompt' Value='Roomler Agent Installation' />

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <!-- Per-user install under %LOCALAPPDATA%\Programs\roomler-agent.
                 ICE38 requires components in a user-profile directory to use
                 an HKCU registry value as their KeyPath (not a file). ICE64
                 requires a RemoveFolder entry for every user-profile dir. -->
            <Directory Id='LocalAppDataFolder'>
                <Directory Id='ProgramsFolder' Name='Programs'>
                    <Directory Id='APPLICATIONFOLDER' Name='roomler-agent'>
                        <Component Id='AgentExe' Guid='3A8C9F21-4E7D-4A8E-9F3B-8D1C2E7F5A62'>
                            <RegistryValue
                                Root='HKCU'
                                Key='Software\Roomler\Agent'
                                Name='installed_exe'
                                Type='integer'
                                Value='1'
                                KeyPath='yes' />
                            <File
                                Id='roomler_agent_exe'
                                Name='roomler-agent.exe'
                                DiskId='1'
                                Source='target\release\roomler-agent.exe' />
                            <RemoveFolder
                                Id='RemoveAppFolder'
                                Directory='APPLICATIONFOLDER'
                                On='uninstall' />
                            <RemoveFolder
                                Id='RemoveProgramsFolder'
                                Directory='ProgramsFolder'
                                On='uninstall' />
                        </Component>
                        <Component Id='LicenseTxt' Guid='4B1D2E80-6F3C-4B2A-9E1D-7A2B3C4D5E6F'>
                            <RegistryValue
                                Root='HKCU'
                                Key='Software\Roomler\Agent'
                                Name='installed_license'
                                Type='integer'
                                Value='1'
                                KeyPath='yes' />
                            <File
                                Id='license_txt'
                                Name='LICENSE.txt'
                                DiskId='1'
                                Source='LICENSE' />
                        </Component>
                        <Component Id='ReadmeTxt' Guid='5C2E3F91-7A4D-4C3B-AF2E-8B3C4D5E6F70'>
                            <RegistryValue
                                Root='HKCU'
                                Key='Software\Roomler\Agent'
                                Name='installed_readme'
                                Type='integer'
                                Value='1'
                                KeyPath='yes' />
                            <File
                                Id='readme_txt'
                                Name='README.txt'
                                DiskId='1'
                                Source='agents\roomler-agent\packaging\windows\README.txt' />
                        </Component>
                    </Directory>
                </Directory>
            </Directory>

            <!-- Start Menu shortcut (already HKCU-keyed, already cleans up) -->
            <Directory Id='ProgramMenuFolder'>
                <Directory Id='ProgramMenuSubfolder' Name='Roomler'>
                    <Component Id='ApplicationShortcut' Guid='6D3F4A02-8B5E-4D4C-B03F-9C4D5E6F7081'>
                        <Shortcut
                            Id='AgentShortcut'
                            Name='Roomler Agent'
                            Description='Roomler AI remote-control agent (signalling)'
                            Target='[APPLICATIONFOLDER]roomler-agent.exe'
                            Arguments='run'
                            WorkingDirectory='APPLICATIONFOLDER' />
                        <RemoveFolder Id='CleanupProgramMenuSubfolder' On='uninstall' />
                        <RegistryValue
                            Root='HKCU'
                            Key='Software\Roomler\Agent'
                            Name='installed'
                            Type='integer'
                            Value='1'
                            KeyPath='yes' />
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Complete'
            Title='Roomler Agent'
            Description='The Roomler AI remote-control agent.'
            Display='expand'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            InstallDefault='local'
            Absent='disallow'>
            <ComponentRef Id='AgentExe' />
            <ComponentRef Id='LicenseTxt' />
            <ComponentRef Id='ReadmeTxt' />
            <ComponentRef Id='ApplicationShortcut' />
        </Feature>

        <Property Id='ARPHELPLINK' Value='https://roomler.ai/' />
        <Property Id='ARPURLINFOABOUT' Value='https://roomler.ai/' />

        <!--
          Postinstall hook: register the Scheduled Task auto-start
          immediately after the EXE lands on disk. Runs deferred +
          impersonated as the installing user (default for perUser
          MSIs) so the task is registered against their account.
          Return="ignore" so a registration failure (e.g. existing
          task with a tightened ACL) doesn't fail the install — the
          operator can recover with manual schtasks /Delete and
          re-run `service install`.
        -->
        <CustomAction
            Id='RegisterAutostart'
            FileKey='roomler_agent_exe'
            ExeCommand='service install'
            Execute='deferred'
            Impersonate='yes'
            Return='ignore' />

        <!--
          Symmetric uninstall hook: tear down the Scheduled Task
          BEFORE the EXE is removed from disk (the action shells
          out to the EXE itself, so it must still be present).
          Only fires during full uninstall (REMOVE="ALL"); a
          maintenance/repair leaves the task alone.
        -->
        <CustomAction
            Id='UnregisterAutostart'
            FileKey='roomler_agent_exe'
            ExeCommand='service uninstall'
            Execute='deferred'
            Impersonate='yes'
            Return='ignore' />

        <InstallExecuteSequence>
            <!--
              Run RegisterAutostart on every fresh install, repair,
              and MajorUpgrade. Skip during full uninstall — there's
              nothing to register and the EXE is about to be deleted
              anyway. The condition leaves it active for upgrade
              installs (which are technically "REMOVE=ALL" of the
              old + install of the new, scheduled separately).
            -->
            <Custom Action='RegisterAutostart' After='InstallFiles'>
                NOT (REMOVE="ALL")
            </Custom>
            <!--
              Run UnregisterAutostart only during full uninstall,
              and BEFORE RemoveFiles so the EXE we shell out to is
              still on disk.
            -->
            <Custom Action='UnregisterAutostart' Before='RemoveFiles'>
                REMOVE="ALL"
            </Custom>
        </InstallExecuteSequence>
    </Product>
</Wix>
